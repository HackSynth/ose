# ==================================
# OSE Configuration / OSE 配置
# ==================================
# Copy this file to .env and fill in the values
# 复制此文件为 .env 并填写配置值

# --- Database / 数据库 ---
# SQLite (default for development / 开发默认)
DATABASE_URL="file:./dev.db"
# PostgreSQL (recommended for production / 生产推荐)
# DATABASE_URL="postgresql://user:password@localhost:5432/ose"

# --- Authentication / 认证 ---
# Generate with: openssl rand -base64 32
# 使用 openssl rand -base64 32 生成
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"
# Compatibility aliases for Auth.js deployments / Auth.js 兼容变量
AUTH_SECRET="your-secret-here"
AUTH_URL="http://localhost:3000"

# --- Exam / 考试 ---
# Optional public target exam date / 可选：目标考试日期
NEXT_PUBLIC_EXAM_DATE="2026-05-23"

# --- AI Provider / AI 供应商 ---
# Options: claude | openai | gemini | custom
# 选项：claude | openai | gemini | custom
# Leave empty to auto-detect based on available API keys
# 留空则按 Claude > OpenAI > Gemini > Custom 顺序自动检测
AI_PROVIDER=

# Claude (Anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=

# Custom (OpenAI-compatible endpoint / OpenAI 兼容接口)
# Works with: Ollama, DeepSeek, Qwen, vLLM, LM Studio, Azure OpenAI, etc.
# 支持：Ollama、DeepSeek、通义千问、vLLM、LM Studio、Azure OpenAI 等
CUSTOM_API_KEY=
CUSTOM_BASE_URL=
CUSTOM_MODEL=
