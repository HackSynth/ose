DATABASE_URL="file:./dev.db"
AUTH_SECRET="change-me"
AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_EXAM_DATE="2026-05-23"

# ========== AI Provider Configuration / AI 供应商配置 ==========
# Current provider / 当前使用的供应商：claude | openai | gemini | custom
AI_PROVIDER=claude

# --- Claude (Anthropic) ---
ANTHROPIC_API_KEY=your-key-here
# Optional custom endpoint, useful for self-hosted proxy / 可选自定义接口地址
ANTHROPIC_BASE_URL=
# Optional model name, default: claude-sonnet-4-5-20250929 / 可选模型名
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# --- OpenAI ---
OPENAI_API_KEY=your-key-here
# Optional custom endpoint, default: https://api.openai.com/v1 / 可选自定义接口地址
OPENAI_BASE_URL=
# Optional model name, default: gpt-4o-mini / 可选模型名
OPENAI_MODEL=gpt-4o-mini

# --- Google Gemini ---
GEMINI_API_KEY=your-key-here
# Optional model name, default: gemini-2.5-flash / 可选模型名
GEMINI_MODEL=gemini-2.5-flash

# --- Custom (OpenAI-compatible API) / 自定义 OpenAI 兼容接口 ---
# Works with Ollama, vLLM, LocalAI, LM Studio, Azure OpenAI, DeepSeek, Qwen, GLM and more.
CUSTOM_API_KEY=your-key-here
# Required custom base URL, example: http://localhost:11434/v1 / 必填自定义接口地址
CUSTOM_BASE_URL=http://localhost:11434/v1
# Model name exposed by your service / 服务暴露的模型名称
CUSTOM_MODEL=llama3
